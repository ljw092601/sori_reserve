# 이 파일을 .env.local 로 복사한 뒤 실제 값을 넣으세요. (.env.local은 git에 올라가지 않음)

# Supabase 대시보드 > Settings > API 에서 확인
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth.js 세션 암호화 키 — `npx auth secret` 으로 생성
AUTH_SECRET=your-auth-secret

# 네이버 개발자 센터(developers.naver.com) > 애플리케이션 등록에서 발급
# 사용 API: 네이버 로그인 / 콜백 URL: http://localhost:3000/api/auth/callback/naver
AUTH_NAVER_ID=your-naver-client-id
AUTH_NAVER_SECRET=your-naver-client-secret
